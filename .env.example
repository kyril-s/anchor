# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Optional Notion fallback values for local development.
# In the app UI, users can still provide their own key/DB IDs.
NOTION_API_KEY=""
NOTION_TASKS_DB_ID=""
NOTION_NOTES_DB_ID=""
